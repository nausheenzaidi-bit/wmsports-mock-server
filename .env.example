# Copy to .env and fill in. .env is gitignored.

# ─── Server ──────────────────────────────────────────────────────────────────
PORT=4010

# ─── Microcks (GQA shared instance) ──────────────────────────────────────────
MICROCKS_URL=https://microcks-sandbox-dev.gqa.discomax.com
MICROCKS_KEYCLOAK_TOKEN_URL=https://keycloak-microcks-sandbox-dev.gqa.discomax.com/realms/microcks/protocol/openid-connect/token
MICROCKS_CLIENT_ID=wmsports-svc-user
MICROCKS_CLIENT_SECRET=
MICROCKS_SERVICE_PREFIX=wmsports-
STATE_FILE_PATH=/data/state.json

# ─── Dashboard auth (Okta SAML) ──────────────────────────────────────────────
# Leave AUTH_ENABLED=false until Okta admin returns the IdP metadata URL (or
# the manual SSO URL + signing cert). When enabled, browsers are redirected
# to Okta over SAML; CI / mobile / automation send X-API-Key instead.
AUTH_ENABLED=false

# Identifier we send Okta as our SP. Must match the "Audience URI / SP Entity
# ID" the Okta admin configured on the SAML app.
SAML_ENTITY_ID=wmsports-mock-server

# Where Okta POSTs the SAML response — must match the ACS URL registered on
# the Okta SAML app.
#   Local dev:  http://localhost:4010/auth/saml/callback
#   EC2 (IP):   http://172.16.46.240:4010/auth/saml/callback
#   ALB (DNS):  https://mock-server.gqa.discomax.com/auth/saml/callback
SAML_CALLBACK_URL=http://localhost:4010/auth/saml/callback

# Easiest path: paste the metadata URL Okta admin gives you. The app fetches
# it on first login and extracts entryPoint / cert / issuer automatically.
SAML_IDP_METADATA_URL=

# Manual fallback — only needed if Okta doesn't expose a metadata URL. Set
# SAML_IDP_SSO_URL and SAML_IDP_CERT (PEM, single line or multi-line both ok).
# SAML_IDP_ENTITY_ID is optional but tightens issuer matching when set.
SAML_IDP_ENTITY_ID=
SAML_IDP_SSO_URL=
SAML_IDP_CERT=

# Name of the SAML attribute that holds group memberships. Okta typically
# sends `groups` when a Group Attribute Statement is configured on the SAML
# app. Some IdPs use `memberOf`. Leave default unless told otherwise.
SAML_GROUP_ATTRIBUTE=groups

# 64+ random hex chars. Generate with: openssl rand -hex 32
SESSION_SECRET=

# Static key for service-to-service callers (CI runners, mobile apps,
# monitoring). Generate with: openssl rand -hex 32. Rotate by changing this
# value and redeploying.
MOCK_API_KEY=

# Optional comma-separated Okta group names. When set, only members of at
# least one of these groups can log in. Leave empty to allow any user
# assigned to the SAML app in Okta.
# Example: AUTH_ALLOWED_GROUPS=gt-sports-tools-eng,gt-sports-br-services,gt-gqa-qe
AUTH_ALLOWED_GROUPS=

# ─── AI (optional) ───────────────────────────────────────────────────────────
# GROQ_API_KEY=
