    "cors": "^2.8.5",
    "express": "^4.18.2",
    "express-session": "^1.18.0",
    "graphql": "^16.13.1",
    "js-yaml": "^4.1.1",
    "passport": "^0.7.0",
    "xml2js": "^0.6.2"
  }
}
